# Use `./forum env-sync` to append missing keys from this file into `.env`.
# Existing `.env` values are never overwritten, and process environment
# variables still take precedence over `.env`.
# Restart the relevant process after changing `.env`.

# Optional moderator allowlist. Comma-separated or space-separated
# OpenPGP fingerprints allowed to submit signed moderation actions.
# Example: FORUM_MODERATOR_FINGERPRINTS=ABCDEF0123456789,0123456789ABCDEF
# FORUM_MODERATOR_FINGERPRINTS=

# Optional repository root override for read/write paths.
# Example: FORUM_REPO_ROOT=/srv/forum
# FORUM_REPO_ROOT=

# Optional bind host for `./forum start` and `scripts/run_read_only.py`.
# FORUM_HOST=127.0.0.1

# Optional bind port for `./forum start` and `scripts/run_read_only.py`.
# FORUM_PORT=8000

# Optional shared site title shown in the header and homepage document title.
# FORUM_SITE_TITLE=Forum Reader

# Dedalus Labs API key for server-side LLM calls.
DEDALUS_API_KEY=

# Enable one best-effort Dedalus-generated assistant reply after a new thread is created.
FORUM_ENABLE_THREAD_AUTO_REPLY=0

# Require browser proof-of-work before accepting a signed user's first post/public-key bootstrap.
FORUM_ENABLE_FIRST_POST_POW=0

# Difficulty for first-post proof-of-work, measured in leading zero bits for the hash target.
FORUM_FIRST_POST_POW_DIFFICULTY=18

# Allow ordinary thread/reply posting to fall back to unsigned submission when browser signing is unavailable.
# Keep this disabled if you want /api/create_thread and /api/create_reply to require signatures.
FORUM_ENABLE_UNSIGNED_POST_FALLBACK=0

# Show the optional "Kindness first" message band above the shared page header.
FORUM_ENABLE_KINDNESS_HEADER=0

# Expose the unfinished account merge feature in the UI and API surfaces.
FORUM_ENABLE_ACCOUNT_MERGE=0

# Reject new profile username claims that collide with an existing canonical account's normalized username route.
FORUM_PREVENT_DUPLICATE_USERNAMES=0

# Assistant signing key paths for canonical auto-reply posting.
# FORUM_THREAD_AUTO_REPLY_PRIVATE_KEY_PATH=/srv/forum/keys/thread-auto-reply-private.asc
# FORUM_THREAD_AUTO_REPLY_PUBLIC_KEY_PATH=/srv/forum/keys/thread-auto-reply-public.asc
